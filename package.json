{
  "name": "lk21-api",
  "version": "1.0.0",
  "description": "Unofficial LK21 API",
  "main": "dist/index.js",
  "private": true,
  "_moduleAliases": {
    "@": "dist"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "watch": "tsc -w",
    "serve": "concurrently \"npm run watch\" \"nodemon dist/index.js\"",
    "start": "node dist/index.js",
    "prepare": "is-ci || husky install",
    "format": "prettier --write ."
  },
  "keywords": [
    "lk21-api",
    "movies-streaming",
    "web-scraping"
  ],
  "author": "Febriadji",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.3.4",
    "cheerio": "^1.0.0-rc.12",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "is-ci": "^3.0.1",
    "module-alias": "^2.2.3",
    "morgan": "^1.10.0",
    "tsc-alias": "^1.8.7",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^17.4.4",
    "@types/cheerio": "^0.22.31",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/morgan": "^1.9.4",
    "@types/node": "^18.15.3",
    "@typescript-eslint/eslint-plugin": "^5.55.0",
    "@typescript-eslint/parser": "^5.55.0",
    "eslint": "^8.36.0",
    "eslint-config-prettier": "^8.7.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "nodemon": "^2.0.21",
    "prettier": "^2.8.4"
  }
}
